# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to git or share it with anyone.

# Your MongoDB Atlas connection string (from "Choose a connection method" -> "Drivers")
# Looks like: mongodb+srv://<username>:<password>@<cluster-url>/cafeDb?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_db_user:your_password@your-cluster.mongodb.net/cafeDb?retryWrites=true&w=majority

# Port the server runs on locally
PORT=3000
